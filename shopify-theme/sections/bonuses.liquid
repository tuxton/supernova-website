<section class="sn-bonuses sn-section" id="bonos">
  <div class="sn-container--md">
    <div class="sn-bonuses__header">
      <p class="sn-label">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline; vertical-align:-2px; margin-right:6px;"><polyline points="20 12 20 22 4 22 4 12"></polyline><rect x="2" y="7" width="20" height="5"></rect><line x1="12" y1="22" x2="12" y2="7"></line><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path></svg>
        {{ section.settings.label_text }}
      </p>
      <h2 class="sn-heading sn-heading--lg">{{ section.settings.title }}</h2>
    </div>

    <div class="sn-bonuses__list">
      {% for block in section.blocks %}
        {% if block.type == 'bonus' %}
          <div class="sn-bonuses__card" {{ block.shopify_attributes }}>
            <span class="sn-bonuses__icon">
              {% if block.settings.icon == 'document' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
              {% elsif block.settings.icon == 'audio' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"></path><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"></path></svg>
              {% elsif block.settings.icon == 'community' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
              {% endif %}
            </span>
            <div class="sn-bonuses__card-body">
              <p class="sn-bonuses__number">Bono {{ forloop.index }}</p>
              <h3 class="sn-heading sn-heading--md">{{ block.settings.title }}</h3>
              <p class="sn-text">{{ block.settings.description }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bonos Especiales",
  "settings": [
    {
      "type": "text",
      "id": "label_text",
      "label": "Etiqueta",
      "default": "Bonos especiales"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Para acompanar tu viaje"
    }
  ],
  "blocks": [
    {
      "type": "bonus",
      "name": "Bono",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icono",
          "options": [
            { "value": "document", "label": "Documento" },
            { "value": "audio", "label": "Audio" },
            { "value": "community", "label": "Comunidad" }
          ],
          "default": "document"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titulo del bono",
          "default": "Mini cuaderno de integracion (PDF)"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripcion",
          "default": "Ejercicios simples para expandir lo que el libro despierta."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bonos Especiales",
      "blocks": [
        { "type": "bonus", "settings": { "icon": "document", "title": "Mini cuaderno de integracion (PDF)", "description": "Ejercicios simples para expandir lo que el libro despierta." } },
        { "type": "bonus", "settings": { "icon": "audio", "title": "Audio de meditacion \"Encender tu propia luz\"", "description": "Activacion breve para sostener tu energia." } },
        { "type": "bonus", "settings": { "icon": "community", "title": "Acceso anticipado a mis proximos circulos y talleres", "description": "Ser de las primeras en participar de mi espacio de acompanamiento." } }
      ]
    }
  ]
}
{% endschema %}
