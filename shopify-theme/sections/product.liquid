{% comment %}
Product section — renders a simple product detail block with add-to-cart form.
Intended to be anchored from the CTA (id="producto").
Uses the official Shopify {% form 'product' %} tag for correct cart/add action,
CSRF token, and compatibility with Shopify apps.
{% endcomment %}

{%- liquid
  assign product_for_section = nil
  if product and product != empty
    assign product_for_section = product
  elsif section.settings.product != blank
    assign product_for_section = section.settings.product
  endif

  comment
    Fallback: si la seccion esta embebida en index.json y el product picker
    no esta configurado, intentar inferir el producto por handle desde la URL
    o usando all_products con un handle conocido.
  endcomment
  if product_for_section == blank or product_for_section == nil
    assign path_parts = request.path | split: '/' 
    assign last_part = path_parts | last
    if last_part != blank
      assign inferred = all_products[last_part]
      if inferred != nil and inferred.title != blank
        assign product_for_section = inferred
      endif
    endif
  endif

  comment
    Ultimo fallback: handle hardcodeado para cuando la seccion vive
    en la landing page y no hay producto en la URL ni en el picker.
  endcomment
  if product_for_section == blank or product_for_section == nil
    assign product_for_section = all_products['ser-supernova']
  endif
-%}

<section id="producto" class="sn-product sn-section">
  {% if product_for_section != blank and product_for_section != nil and product_for_section.title != blank %}

    {% if product_for_section.featured_image %}
      <div class="sn-product__bg-wrap">
        <img
          src="{{ product_for_section.featured_image | image_url: width: 1920 }}"
          alt="{{ product_for_section.featured_image.alt | default: product_for_section.title | escape }}"
          class="sn-product__bg-img"
          loading="lazy"
        >
        <div class="sn-product__overlay"></div>
      </div>
    {% endif %}

    <div class="sn-product__inner">
      <h2 class="sn-heading sn-heading--lg sn-heading--light">{{ product_for_section.title }}</h2>

      {% if product_for_section.vendor != blank %}
        <p class="sn-product__vendor">{{ product_for_section.vendor }}</p>
      {% endif %}

      {%- assign current_variant = product_for_section.selected_or_first_available_variant -%}

      <div class="sn-product__price">
        {{ current_variant.price | money }}
      </div>

      {% form 'product', product_for_section, id: 'sn-product-form', class: 'sn-product-form' %}
        <input type="hidden" name="id" value="{{ current_variant.id }}">
        <input type="hidden" name="quantity" value="1">

        <div class="sn-product__actions">
          <button
            type="submit"
            name="add"
            class="sn-btn sn-btn--gold-lg sn-add-to-cart"
            {% unless current_variant.available %}disabled{% endunless %}
          >
            {% if current_variant.available %}
              Comprar ahora
            {% else %}
              Agotado
            {% endif %}
          </button>
        </div>

        <div id="sn-product-confirm" class="sn-product__confirm" aria-live="polite" style="display:none;">
          <strong>¡Listo! El eBook fue agregado al carrito.</strong>
        </div>
      {% endform %}

      {% if product_for_section.description != blank %}
        <p class="sn-product__desc">
          {{ product_for_section.description | strip_html | truncate: 300 }}
        </p>
      {% endif %}
    </div>

    {{ 'add-to-cart.js' | asset_url | script_tag }}

  {% else %}
    <div class="sn-product__empty">
      <p>No se ha configurado un producto para esta sección. Asigná el producto desde el Theme Editor.</p>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Producto (ancla CTA)",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Producto"
    }
  ],
  "presets": [
    {
      "name": "Producto"
    }
  ]
}
{% endschema %}