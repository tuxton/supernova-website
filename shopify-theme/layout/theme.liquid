<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#d4a8c8">

    <title>{{ page_title }} — {{ shop.name }}</title>
    <meta name="description" content="{{ page_description | escape }}">

    {{ 'theme.css' | asset_url | stylesheet_tag }}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500;1,600&display=swap" rel="stylesheet">

    {{ content_for_header }}
  </head>

  <body class="sn-body">
    {% section 'navbar' %}

    <main role="main">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    {{ 'theme.js' | asset_url | script_tag }}
  </body>
</html>
